int binarySech(int key, int* arr, int n) {
	int left = 0;
	int mid = 0;
	int right = n - 1 ;
    while (left < right) {
        mid = (left + right) / 2;
        if (key < arr[mid])right = mid;
        else if (key > arr[mid])left = mid;
        else return mid;
    }
    return -1;
}

void bubbleSort(Train arr[], int n, bool (*comp)(const Train&, const Train&)) {
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            if (comp(arr[j + 1], arr[j])) {
                swap(arr[j], arr[j + 1]);
            }
        }
    }
}

void selectionSort(Train arr[], int n, bool (*comp)(const Train&, const Train&)) {
    for (int i = 0; i < n - 1; i++) {
        int minIdx = i;
        for (int j = i + 1; j < n; j++) {
            if (comp(arr[j], arr[minIdx])) {
                minIdx = j;
            }
        }
        if (minIdx != i) {
            swap(arr[i], arr[minIdx]);
        }
    }
}
void insertionSort(Train arr[], int n, bool (*comp)(const Train&, const Train&)) {
    for (int i = 1; i < n; i++) {
        Train key = arr[i];
        int j = i - 1;
        while (j >= 0 && comp(key, arr[j])) {
            arr[j + 1] = arr[j];
            j--;
        }
        arr[j + 1] = key;
    }
}
void shellSort(Train arr[], int n, bool (*comp)(const Train&, const Train&)) {
    // Начинаем с большого шага, затем уменьшаем
    for (int gap = n / 2; gap > 0; gap /= 2) {
        // Делаем insertion sort для текущего шага
        for (int i = gap; i < n; i++) {
            Train temp = arr[i];
            int j;
            for (j = i; j >= gap && comp(temp, arr[j - gap]); j -= gap) {
                arr[j] = arr[j - gap];
            }
            arr[j] = temp;
        }
    }
}
void combSort(Train arr[], int n, bool (*comp)(const Train&, const Train&)) {
    int gap = n;
    bool swapped = true;
    const double shrink = 1.3;  // фактор уменьшения

    while (gap > 1 || swapped) {
        // Уменьшаем шаг
        gap = (int)(gap / shrink);
        if (gap < 1) gap = 1;

        swapped = false;

        // Сравниваем элементы с текущим шагом
        for (int i = 0; i < n - gap; i++) {
            if (comp(arr[i + gap], arr[i])) {
                swap(arr[i], arr[i + gap]);
                swapped = true;
            }
        }
    }
}



















    
