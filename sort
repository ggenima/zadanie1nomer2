// Простая реализация бинарного поиска в массиве структур
int binarySearch(Train* arr, int size, int key) {
    int left = 0, right = size - 1;
    while (left <= right) {
        int mid = left + (right - left) / 2;
        if (arr[mid].number == key)
            return mid;
        if (arr[mid].number < key)
            left = mid + 1;
        else
            right = mid - 1;
    }
    return -1;
}
bool compareByStation(const Train& a, const Train& b) {
    return strcmp(a.station, b.station) < 0;  // a.station раньше по алфавиту
}

// Сравнение по номеру (возрастание)
bool compareByNumber(const Train& a, const Train& b) {
    return a.number < b.number;  // у a номер меньше
}

// Сравнение по времени (возрастание)
bool compareByTime(const Train& a, const Train& b) {
    return a.time < b.time;  // у a время меньше
}

